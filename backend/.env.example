APP_NAME=Pixpress1 API
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://user:password@host:55432/dbname
TEST_DATABASE_URL=postgresql+psycopg://user:password@host:55432/dbname_test
REDIS_URL=redis://host:6379/0
MINIO_ENDPOINT=127.0.0.1:9100
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=pixpress1
MINIO_SECURE=false
MINIO_PUBLIC_BASE_URL=
UPLOADS_DIR=uploads
AUTH_SECRET_KEY=change-me-in-production
SECRETS_MASTER_KEY=change-me-too
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=1440
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type
STORAGE_BACKEND=minio
UPLOAD_MAX_FILE_SIZE_BYTES=20971520
UPLOAD_MAX_BATCH_SIZE_BYTES=209715200
UPLOAD_MAX_IMAGE_PIXELS=40000000
UPLOAD_MAX_FILES_PER_REQUEST=200
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS=900
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=10/hour
RATE_LIMIT_UPLOAD=20/minute
RATE_LIMIT_TASK_TRIGGER=10/minute
RATE_LIMIT_EXPORT=10/minute

# AI runtime
AI_ENABLED=false
AI_PROVIDER_B1=
AI_PROVIDER_B2=openai_compatible
AI_PROVIDER_B3=openai_compatible
AI_MODE_B1=hybrid
AI_MODE_B2=llm
AI_MODE_B3=llm
AI_FALLBACK_ON_ERROR=true
API_KEY=
API_URL=
ANTHROPIC_API_KEY=
AI_MODEL_B1=
AI_MODEL_B2=gpt4-mini
AI_MODEL_B3=gpt4-mini
AI_REQUEST_TIMEOUT_SECONDS=60
AI_PROVIDER_MAX_RETRIES=2
AI_B1_MAX_PARALLEL=3
AI_IMAGE_MAX_EDGE=1800
AI_DEBUG_PERSIST=true
RUN_LIVE_AI_TESTS=false

# Local photo cleaning runtime
CLEANING_PIPELINE_VERSION=b1-local-v1
CLEANING_ANALYSIS_MAX_PARALLEL=3
CLEANING_ROLLOUT_PERCENT=100
CLEANING_AUTO_EXCLUDE_MODE=exact_only
