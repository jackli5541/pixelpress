# LangSmith 追踪配置（可选，不配置默认关闭）
# 获取 API key: https://smith.langchain.com/settings
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_api_key_here
LANGSMITH_PROJECT=pixelpress
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 数据库连接（启动: docker compose up -d / 停止: docker compose down）
PIXELPRESS_DATABASE_URL=postgresql://pixelpress:pixelpress@localhost:5432/pixelpress

# PixelPress 应用配置（以下为默认值，可不改）
PIXELPRESS_APP_NAME=PixelPress Backend
PIXELPRESS_APP_VERSION=0.1.0
