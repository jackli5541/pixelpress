APP_NAME=pixpress1
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/pixpress1
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/pixpress1_test
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pixpress1
MINIO_SECURE=false
MINIO_PUBLIC_BASE_URL=
UPLOADS_DIR=uploads
AUTH_SECRET_KEY=replace-with-a-unique-32-character-development-secret
SECRETS_MASTER_KEY=replace-with-a-different-32-character-development-secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=120
CORS_ALLOW_ORIGINS=["http://127.0.0.1","http://localhost"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
STORAGE_BACKEND=minio
UPLOAD_MAX_FILE_SIZE_BYTES=31457280
UPLOAD_MAX_BATCH_SIZE_BYTES=209715200
UPLOAD_MAX_IMAGE_PIXELS=80000000
UPLOAD_MAX_FILES_PER_REQUEST=100
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS=900
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_UPLOAD=30/minute
RATE_LIMIT_TASK_TRIGGER=10/minute
RATE_LIMIT_EXPORT=10/minute

# AI runtime configuration. Keep real credentials only in the ignored .env file.
AI_ENABLED=false
AI_FALLBACK_ON_ERROR=true
AI_REQUEST_TIMEOUT_SECONDS=60
AI_PROVIDER_MAX_RETRIES=2
AI_IMAGE_MAX_EDGE=1800
AI_DEBUG_PERSIST=true
RUN_LIVE_AI_TESTS=false

# Chapter copy generation (OpenAI-compatible endpoint).
AI_CHAPTER_PROVIDER=openai_compatible
AI_CHAPTER_API_URL=https://api.example.com/v1
AI_CHAPTER_API_KEY=
AI_CHAPTER_MODEL=your-model-name

# Multimodal embedding provider.
THEME_CURATION_ENABLED=true
AI_CHAPTER_EMBEDDING_PROVIDER=dashscope_multimodal_embedding
AI_CHAPTER_EMBEDDING_API_URL=https://api.example.com/v1
AI_CHAPTER_EMBEDDING_API_KEY=
AI_CHAPTER_EMBEDDING_MODEL=your-embedding-model

# Layout copy generation (OpenAI-compatible endpoint).
AI_LAYOUT_PROVIDER=openai_compatible
AI_LAYOUT_API_URL=https://api.example.com/v1
AI_LAYOUT_API_KEY=
AI_LAYOUT_MODEL=your-model-name

# Local photo-cleaning runtime configuration.
CLEANING_PIPELINE_VERSION=b2-local-v3
CLEANING_ANALYSIS_MAX_PARALLEL=3
CLEANING_ROLLOUT_PERCENT=100
CLEANING_AUTO_EXCLUDE_MODE=exact_and_clear_quality

# Chapter clustering runtime configuration.
THEME_PIPELINE_VERSION=theme-curation-v7-embedding-only
THEME_CANDIDATE_COUNT=3
THEME_RELEVANCE_CALIBRATION_PATH=
THEME_PROVISIONAL_AUTO_DECISION_ENABLED=true
THEME_PROVISIONAL_DECISION_THRESHOLD=0.60
CHAPTER_REPRESENTATIVE_PHOTO_COUNT=3
CHAPTER_NAMING_MAX_PARALLEL=2
CHAPTER_FEATURE_VERSION=c3-semantic-embedding-v1
CHAPTER_EMBEDDING_DIMENSION=512
CHAPTER_EMBEDDING_BATCH_SIZE=8
